  "name": "recycle-startup-backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:setup": "ts-node scripts/setup-db.ts",
    "db:seed": "ts-node scripts/seed-admin.ts",
